ARG PYTHON_BASE_IMAGE=m.daocloud.io/docker.io/library/python:3.11-slim

FROM ${PYTHON_BASE_IMAGE} AS builder

WORKDIR /build
ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1

ARG PIP_INDEX_URL=https://mirrors.aliyun.com/pypi/simple/
ARG PIP_TRUSTED_HOST=mirrors.aliyun.com

COPY ai-analysis/requirements.txt ./
RUN pip config set global.index-url "${PIP_INDEX_URL}" && \
    pip config set install.trusted-host "${PIP_TRUSTED_HOST}" && \
    python -m pip install --upgrade pip && \
    pip install --prefix=/install -r requirements.txt

FROM ${PYTHON_BASE_IMAGE}

ENV TZ=Asia/Shanghai \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

ARG APT_DEBIAN_MIRROR=https://mirrors.aliyun.com/debian
ARG APT_SECURITY_MIRROR=https://mirrors.aliyun.com/debian-security

RUN set -eux; \
    for f in /etc/apt/sources.list /etc/apt/sources.list.d/*.list /etc/apt/sources.list.d/*.sources; do \
      [ -f "$f" ] || continue; \
      sed -i "s|http://deb.debian.org/debian|${APT_DEBIAN_MIRROR}|g; s|https://deb.debian.org/debian|${APT_DEBIAN_MIRROR}|g; s|http://security.debian.org/debian-security|${APT_SECURITY_MIRROR}|g; s|https://security.debian.org/debian-security|${APT_SECURITY_MIRROR}|g; s|http://deb.debian.org/debian-security|${APT_SECURITY_MIRROR}|g; s|https://deb.debian.org/debian-security|${APT_SECURITY_MIRROR}|g" "$f"; \
    done; \
    apt-get -o Acquire::Retries=5 -o Acquire::http::Timeout=30 -o Acquire::https::Timeout=30 update; \
    apt-get -o Acquire::Retries=5 install -y --no-install-recommends \
      ca-certificates \
      tzdata \
      ffmpeg \
      libglib2.0-0 \
      libstdc++6; \
    rm -rf /var/lib/apt/lists/*

COPY --from=builder /install /usr/local
COPY ai-analysis/ /app/

EXPOSE 50051 50052

CMD ["python", "main.py", "--port", "50051", "--http-port", "50052"]
